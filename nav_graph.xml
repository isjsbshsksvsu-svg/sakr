<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/inputFragment">

    <fragment
        android:id="@+id/inputFragment"
        android:name="com.sakr.arabicwordformatter.presentation.input.InputFragment"
        android:label="@string/input_title"
        tools:layout="@layout/fragment_input">
        <action
            android:id="@+id/action_input_to_preview"
            app:destination="@id/previewFragment" />
        <action
            android:id="@+id/action_input_to_drafts"
            app:destination="@id/draftsFragment" />
    </fragment>

    <fragment
        android:id="@+id/previewFragment"
        android:name="com.sakr.arabicwordformatter.presentation.preview.PreviewFragment"
        android:label="@string/preview_title"
        tools:layout="@layout/fragment_preview" />

    <fragment
        android:id="@+id/draftsFragment"
        android:name="com.sakr.arabicwordformatter.presentation.drafts.DraftsFragment"
        android:label="@string/drafts_title"
        tools:layout="@layout/fragment_drafts">
        <action
            android:id="@+id/action_drafts_to_preview"
            app:destination="@id/previewFragment" />
    </fragment>

</navigation>
