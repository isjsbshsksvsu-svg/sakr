<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Widget.Sakr.CardHeading" parent="Widget.Material3.CardView.Filled">
        <item name="cardBackgroundColor">@color/heading_bg</item>
        <item name="strokeColor">@color/heading_border</item>
        <item name="strokeWidth">2dp</item>
        <item name="contentPadding">16dp</item>
        <item name="cardCornerRadius">8dp</item>
        <item name="cardElevation">2dp</item>
    </style>

    <style name="Widget.Sakr.CardSubHeading" parent="Widget.Material3.CardView.Filled">
        <item name="cardBackgroundColor">@color/subheading_bg</item>
        <item name="strokeColor">@color/subheading_border</item>
        <item name="strokeWidth">1dp</item>
        <item name="contentPadding">12dp</item>
        <item name="cardCornerRadius">8dp</item>
        <item name="cardElevation">1dp</item>
    </style>

    <style name="Widget.Sakr.CardParagraph" parent="Widget.Material3.CardView.Filled">
        <item name="cardBackgroundColor">@color/para_bg</item>
        <item name="strokeColor">@color/divider</item>
        <item name="strokeWidth">0.5dp</item>
        <item name="contentPadding">12dp</item>
        <item name="cardCornerRadius">6dp</item>
    </style>

    <style name="Widget.Sakr.CardList" parent="Widget.Material3.CardView.Filled">
        <item name="cardBackgroundColor">@color/list_bg</item>
        <item name="strokeColor">@color/divider</item>
        <item name="strokeWidth">0.5dp</item>
        <item name="contentPadding">12dp</item>
        <item name="cardCornerRadius">6dp</item>
    </style>

    <style name="Widget.Sakr.CardTable" parent="Widget.Material3.CardView.Filled">
        <item name="cardBackgroundColor">@color/table_bg</item>
        <item name="strokeColor">@color/divider</item>
        <item name="strokeWidth">0.5dp</item>
        <item name="contentPadding">8dp</item>
        <item name="cardCornerRadius">6dp</item>
    </style>
</resources>
